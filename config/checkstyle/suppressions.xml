<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <suppress files="ScheduleApplication\.java" checks="FinalClass"/>
    <suppress files="ScheduleApplication\.java" checks="HideUtilityClassConstructor"/>
    <suppress files="ScheduleApplication\.java" checks="UnusedImports"/>

    <!-- Pre-existing violations in PDF/HTML report utility classes -->
    <suppress files="TeacherHtmlBuilder\.java" checks=".*"/>
    <suppress files="SchedulePdfStyles\.java" checks=".*"/>
    <suppress files="GroupHtmlBuilder\.java" checks=".*"/>
    <suppress files="PdfReportGenerator\.java" checks=".*"/>
</suppressions>